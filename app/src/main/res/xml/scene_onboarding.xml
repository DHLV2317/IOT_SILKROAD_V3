<?xml version="1.0" encoding="utf-8"?>
<MotionScene xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Definir transiciones entre estados -->
    <Transition
        app:constraintSetStart="@id/start"
        app:constraintSetEnd="@id/end"
        app:duration="800"
        app:motionInterpolator="easeInOut">

        <OnSwipe
            app:touchAnchorId="@id/onboarding_content"
            app:touchAnchorSide="right"
            app:dragDirection="dragRight" />

        <KeyFrameSet>
            <KeyAttribute
                app:motionTarget="@id/onboarding_image"
                app:framePosition="50"
                android:alpha="0.5" />
            
            <KeyAttribute
                app:motionTarget="@id/onboarding_title"
                app:framePosition="30"
                android:alpha="0" />
        </KeyFrameSet>

    </Transition>

    <!-- Estado inicial -->
    <ConstraintSet android:id="@+id/start">
        <Constraint
            android:id="@id/onboarding_image"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/onboarding_title"
            android:layout_marginBottom="32dp"
            android:alpha="1" />

        <Constraint
            android:id="@id/onboarding_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/onboarding_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/onboarding_description"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="16dp"
            android:alpha="1" />

        <Constraint
            android:id="@id/onboarding_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/onboarding_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btn_next"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="48dp"
            android:alpha="1" />

        <Constraint
            android:id="@id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="32dp"
            android:alpha="1" />
    </ConstraintSet>

    <!-- Estado final -->
    <ConstraintSet android:id="@+id/end">
        <Constraint
            android:id="@id/onboarding_image"
            android:layout_width="200dp"
            android:layout_height="200dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/onboarding_title"
            android:layout_marginBottom="32dp"
            android:alpha="0.2"
            android:translationX="-1000dp" />

        <Constraint
            android:id="@id/onboarding_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/onboarding_image"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/onboarding_description"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="16dp"
            android:alpha="0"
            android:translationX="-1000dp" />

        <Constraint
            android:id="@id/onboarding_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/onboarding_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/btn_next"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="48dp"
            android:alpha="0"
            android:translationX="-1000dp" />

        <Constraint
            android:id="@id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="32dp"
            android:alpha="1" />
    </ConstraintSet>

</MotionScene>
