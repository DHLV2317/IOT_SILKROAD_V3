<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ============================================ -->
    <!-- TEMA PRINCIPAL -->
    <!-- ============================================ -->
    <style name="Theme.SilkRoad" parent="Theme.Material3.Light.NoActionBar">
        <!-- Colores Principales -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Colores Secundarios -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Colores de Superficie -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Colores de Fondo -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Colores de Error -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <!-- Tipografía -->
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.SilkRoad.HeadlineLarge</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.SilkRoad.BodyLarge</item>

        <!-- Shapes -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.SilkRoad.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SilkRoad.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.SilkRoad.LargeComponent</item>

        <!-- Barras del sistema -->
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- ============================================ -->
    <!-- TIPOGRAFÍA -->
    <!-- ============================================ -->
    <style name="TextAppearance.SilkRoad.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_display_large</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SilkRoad.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_headline_large</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SilkRoad.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_headline_medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.SilkRoad.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_title_large</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SilkRoad.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.SilkRoad.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_body_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.SilkRoad.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:textSize">@dimen/text_label_large</item>
    </style>

    <!-- ============================================ -->
    <!-- SHAPES -->
    <!-- ============================================ -->
    <style name="ShapeAppearance.SilkRoad.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_sm</item>
    </style>

    <style name="ShapeAppearance.SilkRoad.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_md</item>
    </style>

    <style name="ShapeAppearance.SilkRoad.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_radius_lg</item>
    </style>

    <!-- ============================================ -->
    <!-- BOTONES -->
    <!-- ============================================ -->
    <style name="Widget.SilkRoad.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height_medium</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="elevation">@dimen/elevation_sm</item>
        <item name="android:textSize">@dimen/text_label_large</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.SilkRoad.Button.Filled" parent="Widget.SilkRoad.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
    </style>

    <style name="Widget.SilkRoad.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">@dimen/button_height_medium</item>
        <item name="android:paddingStart">@dimen/spacing_lg</item>
        <item name="android:paddingEnd">@dimen/spacing_lg</item>
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="strokeWidth">2dp</item>
        <item name="cornerRadius">@dimen/corner_radius_md</item>
        <item name="android:textSize">@dimen/text_label_large</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <style name="Widget.SilkRoad.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">@dimen/text_label_large</item>
        <item name="fontFamily">@font/poppins</item>
    </style>

    <!-- ============================================ -->
    <!-- CARDS -->
    <!-- ============================================ -->
    <style name="Widget.SilkRoad.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>

    <style name="Widget.SilkRoad.CardView.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>

    <!-- ============================================ -->
    <!-- TEXT INPUT LAYOUT -->
    <!-- ============================================ -->
    <style name="Widget.SilkRoad.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_md</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- ============================================ -->
    <!-- TOOLBAR -->
    <!-- ============================================ -->
    <style name="Widget.SilkRoad.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/primary</item>
        <item name="titleTextColor">@color/on_primary</item>
        <item name="subtitleTextColor">@color/on_primary</item>
        <item name="android:elevation">@dimen/toolbar_elevation</item>
        <item name="navigationIconTint">@color/on_primary</item>
    </style>

    <!-- ============================================ -->
    <!-- CHIP -->
    <!-- ============================================ -->
    <style name="Widget.SilkRoad.Chip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipBackgroundColor">@color/primary_container</item>
        <item name="android:textColor">@color/on_primary_container</item>
        <item name="chipCornerRadius">@dimen/corner_radius_full</item>
    </style>

    <!-- ============================================ -->
    <!-- DIVIDER -->
    <!-- ============================================ -->
    <style name="Widget.SilkRoad.Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/divider</item>
    </style>

    <!-- ============================================ -->
    <!-- RETROCOMPATIBILIDAD -->
    <!-- ============================================ -->
    <style name="M3_OutlinedButton" parent="Widget.SilkRoad.Button.Outlined" />
    <style name="MDC_OutlinedButton" parent="Widget.SilkRoad.Button.Outlined" />

</resources>
