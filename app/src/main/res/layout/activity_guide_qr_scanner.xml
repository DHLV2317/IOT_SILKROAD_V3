<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- AppBarLayout con Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:elevation="@dimen/elevation_sm"
            app:title="Escanear QR de reserva"
            app:titleTextColor="?attr/colorOnPrimary"
            app:navigationIcon="@drawable/ic_arrow_back_24"
            app:navigationIconTint="?attr/colorOnPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido scrolleable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- 1) Tarjeta de instrucciones / estado -->
            <com.google.android.material.card.MaterialCardView
                style="@style/M3_Card_Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        style="@style/M3_Title_Large"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 Finalizar servicio"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- ESTE ES EL QUE USA LA ACTIVITY -->
                    <TextView
                        android:id="@+id/txtInstructions"
                        style="@style/M3_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Solicite al cliente su código QR. El sistema actualizará el estado: pendiente → aceptado (admin) → check-in → check-out → finalizada."
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2) Tarjeta del área de escaneo (CameraX real) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/M3_Card_Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        style="@style/M3_Title_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼 Área de escaneo"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Preview de la cámara -->
                    <androidx.camera.view.PreviewView
                        android:id="@+id/cameraPreview"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:background="?attr/colorSurfaceContainerHighest"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:scaleType="centerCrop" />

                    <TextView
                        style="@style/M3_Body_Small"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Acerque el código QR dentro del recuadro. El escaneo se realiza automáticamente."
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3) Resultado del escaneo -->
            <com.google.android.material.card.MaterialCardView
                style="@style/M3_Card_Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        style="@style/M3_Title_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Resultado del escaneo"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:background="?attr/colorSurfaceContainerHighest"
                        android:padding="@dimen/spacing_md">

                        <!-- ESTE ES EL QUE USA LA ACTIVITY -->
                        <TextView
                            android:id="@+id/txtScanResult"
                            style="@style/M3_Body_Medium"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Esperando escaneo de código QR...\n\n"
                            android:fontFamily="monospace"
                            android:textColor="?attr/colorOnSurface" />
                    </ScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4) Info de backend / sincronización (opcional) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/M3_Card_Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        style="@style/M3_Title_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔄 Sincronización"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/txtBackendStatus"
                        style="@style/M3_Body_Medium"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Esperando escaneo de tour para actualizar el estado en Firestore…"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>