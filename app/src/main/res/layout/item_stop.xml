<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/M3_Card_Elevated"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginBottom="@dimen/spacing_md">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <!-- Mapa en miniatura -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivMapImage"
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_map"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Contenido de texto -->
        <LinearLayout
            android:id="@+id/contentLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/spacing_md"
            app:layout_constraintTop_toBottomOf="@id/ivMapImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvStopName"
                style="@style/M3_Title_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1° Parada" />

            <TextView
                android:id="@+id/tvStopAddress"
                style="@style/M3_Body_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="@dimen/spacing_xs"
                android:drawablePadding="@dimen/spacing_xs"
                android:drawableStart="@drawable/location_on_24px"
                android:drawableTint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvStopTime"
                style="@style/M3_Body_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiempo en el lugar"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/tvStopCost"
                style="@style/M3_Label_Large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S/. 0.00"
                android:textColor="?attr/colorPrimary"
                android:layout_marginTop="@dimen/spacing_sm" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
