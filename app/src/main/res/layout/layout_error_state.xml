<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/spacing_xl">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:src="@drawable/ic_map_placeholder"
        android:alpha="0.5"
        android:tint="@color/error" />

    <TextView
        style="@style/M3_Headline_Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Error al cargar"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="@dimen/spacing_sm" />

    <TextView
        style="@style/M3_Body_Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No se pudo cargar la información. Por favor, intenta nuevamente."
        android:textColor="@color/text_secondary"
        android:textAlignment="center"
        android:layout_marginBottom="@dimen/spacing_lg" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/retry_button"
        style="@style/M3_FilledButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reintentar"
        android:textAllCaps="false" />

</LinearLayout>
