<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- CONTENIDO PRINCIPAL -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <!-- App Bar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                style="@style/Widget.SilkRoad.Toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:title="Panel de Administración"
                app:navigationIcon="@drawable/ic_menu_24" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Contenido Scrolleable -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/spacing_md">

                <!-- Card de Bienvenida -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.SilkRoad.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    app:cardBackgroundColor="@color/primary_container">

                    <LinearLayout
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/tvWelcome"
                            android:text="¡Bienvenido, Admin!"
                            android:textAppearance="@style/TextAppearance.SilkRoad.HeadlineMedium"
                            android:textColor="@color/on_primary_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="Gestiona tours, reservas y más"
                            android:textAppearance="@style/TextAppearance.SilkRoad.BodyLarge"
                            android:textColor="@color/on_primary_container"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Grid de acciones rápidas -->
                <TextView
                    android:text="Acciones Rápidas"
                    android:textAppearance="@style/TextAppearance.SilkRoad.TitleLarge"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <GridLayout
                    android:columnCount="2"
                    android:rowCount="2"
                    android:alignmentMode="alignBounds"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <!-- Tours -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.SilkRoad.CardView"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/spacing_xs"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/spacing_md"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="@dimen/icon_size_large"
                                android:layout_height="@dimen/icon_size_large"
                                android:src="@drawable/ic_map"
                                app:tint="@color/primary" />

                            <TextView
                                android:text="Tours"
                                android:textAppearance="@style/TextAppearance.SilkRoad.LabelLarge"
                                android:textStyle="bold"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Reservas -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.SilkRoad.CardView"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/spacing_xs"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/spacing_md"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="@dimen/icon_size_large"
                                android:layout_height="@dimen/icon_size_large"
                                android:src="@drawable/baseline_arrow_circle_down_24"
                                app:tint="@color/secondary" />

                            <TextView
                                android:text="Reservas"
                                android:textAppearance="@style/TextAppearance.SilkRoad.LabelLarge"
                                android:textStyle="bold"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Guías -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.SilkRoad.CardView"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/spacing_xs"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/spacing_md"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="@dimen/icon_size_large"
                                android:layout_height="@dimen/icon_size_large"
                                android:src="@drawable/ic_person_24"
                                app:tint="@color/primary" />

                            <TextView
                                android:text="Guías"
                                android:textAppearance="@style/TextAppearance.SilkRoad.LabelLarge"
                                android:textStyle="bold"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Reportes -->
                    <com.google.android.material.card.MaterialCardView
                        style="@style/Widget.SilkRoad.CardView"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="@dimen/spacing_xs"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="@dimen/spacing_md"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="@dimen/icon_size_large"
                                android:layout_height="@dimen/icon_size_large"
                                android:src="@drawable/sp_auto_stories_24px"
                                app:tint="@color/secondary" />

                            <TextView
                                android:text="Reportes"
                                android:textAppearance="@style/TextAppearance.SilkRoad.LabelLarge"
                                android:textStyle="bold"
                                android:layout_marginTop="@dimen/spacing_sm"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                </GridLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer (si lo necesitas) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start" />

</androidx.drawerlayout.widget.DrawerLayout>
