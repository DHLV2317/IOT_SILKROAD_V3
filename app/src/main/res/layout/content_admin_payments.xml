<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <!-- Header tipo card -->
    <com.google.android.material.card.MaterialCardView
        style="@style/M3_Card_Elevated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:id="@+id/tHeader"
                style="@style/M3_Title_Large"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pagos a guías / proveedores"
                android:layout_marginBottom="@dimen/spacing_xs"/>

            <TextView
                android:id="@+id/tSubheader"
                style="@style/M3_Body_Medium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Revisa y gestiona los pagos pendientes, pagados y en revisión."
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Filtros -->
    <LinearLayout
        android:id="@+id/filtersBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/spacing_md">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Buscar por guía o tour"
            app:startIconDrawable="@drawable/ic_search_24"
            app:startIconTint="?attr/colorPrimary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/inputSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="@dimen/spacing_md"
            android:layout_height="0dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:hint="Estado">

            <AutoCompleteTextView
                android:id="@+id/inputStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <!-- Lista de pagos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listPayments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_md" />

    <!-- Botón reporte de pagos -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnExportPayments"
        style="@style/M3_FilledButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Exportar reporte de pagos"
        android:layout_marginTop="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md" />

</LinearLayout>