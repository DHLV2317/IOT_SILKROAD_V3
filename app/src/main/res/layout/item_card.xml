<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/M3_Card_Elevated"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_sm"
    android:layout_marginBottom="@dimen/spacing_sm">

    <LinearLayout
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <RadioButton
            android:id="@+id/rbSelect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/spacing_md" />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvAlias"
                style="@style/M3_Title_Small"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarjeta principal" />

            <TextView
                android:id="@+id/tvBrand"
                style="@style/M3_Body_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VISA (CREDIT)"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvLast4"
                style="@style/M3_Body_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="•••• 4242"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tvBalance"
                style="@style/M3_Label_Medium"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo: S/. 0.00"
                android:textColor="?attr/colorPrimary"
                android:layout_marginTop="@dimen/spacing_xs" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>