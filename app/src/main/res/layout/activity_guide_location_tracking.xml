<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar superior -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:elevation="@dimen/elevation_sm"
            app:titleTextColor="?attr/colorOnPrimary"
            app:navigationIcon="@drawable/ic_arrow_back_24"
            app:navigationIconTint="?attr/colorOnPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ⭐ Mapa del guía (Google Maps) -->
    <fragment
        android:id="@+id/mapGuide"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="250dp" />

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Status Section -->
            <com.google.android.material.card.MaterialCardView
                style="@style/M3_Card_Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        style="@style/M3_Title_Large"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 Estado del Tour"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/txtCurrentStop"
                        style="@style/M3_Body_Large"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parada actual: Cargando..."
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/txtStopCounter"
                        style="@style/M3_Body_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parada 1 de 4"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/txtGpsStatus"
                        style="@style/M3_Body_Medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GPS: Verificando..."
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:id="@+id/txtDemoCoordinates"
                        style="@style/M3_Body_Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Coord. Demo: 0.0000, 0.0000"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textStyle="italic" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botones de acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:layout_marginBottom="@dimen/spacing_lg">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegisterLocation"
                    style="@style/M3_FilledButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Registrar Ubicación Actual"
                    android:layout_marginBottom="@dimen/spacing_md" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextStop"
                    style="@style/M3_FilledButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="➡️ Siguiente Parada"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:enabled="false"
                    app:backgroundTint="?attr/colorSecondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinishTour"
                    style="@style/M3_FilledButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏁 Finalizar Tour"
                    android:visibility="gone"
                    app:backgroundTint="?attr/colorTertiary" />

            </LinearLayout>

            <!-- Historial de ubicaciones -->
            <com.google.android.material.card.MaterialCardView
                style="@style/M3_Card_Elevated"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/spacing_lg">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        style="@style/M3_Title_Large"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Historial de Ubicaciones"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="?attr/colorSurfaceContainerHighest"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:id="@+id/txtLocationHistory"
                            style="@style/M3_Body_Small"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Registros de ubicaciones aparecerán aquí...\n\n"
                            android:fontFamily="monospace"
                            android:textColor="?attr/colorOnSurface" />

                    </ScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>