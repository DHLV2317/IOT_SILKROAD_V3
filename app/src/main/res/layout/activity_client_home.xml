<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.client.ClientHomeActivity">

    <!-- CONTENIDO PRINCIPAL -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background">

        <!-- App Bar con Material Design 3 -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:elevation="@dimen/elevation_sm">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/primary"
                app:titleTextColor="@color/on_primary"
                app:navigationIcon="@drawable/ic_menu_24"
                app:navigationIconTint="@color/on_primary" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Contenido Scrolleable -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Header Card con saludo -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.SilkRoad.CardView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/spacing_md"
                    app:cardBackgroundColor="@color/primary_container"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:id="@+id/tvHello"
                                android:text="Hola, Usuario"
                                android:textAppearance="@style/TextAppearance.SilkRoad.HeadlineMedium"
                                android:textColor="@color/on_primary_container"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:text="¿A dónde vamos hoy?"
                                android:textAppearance="@style/TextAppearance.SilkRoad.BodyMedium"
                                android:textColor="@color/on_primary_container"
                                android:layout_marginTop="@dimen/spacing_xs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnHistory"
                            style="@style/Widget.SilkRoad.Button.Outlined"
                            android:text="Historial"
                            android:textColor="@color/on_primary_container"
                            app:strokeColor="@color/on_primary_container"
                            app:icon="@drawable/baseline_arrow_circle_down_24"
                            app:iconTint="@color/on_primary_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Búsqueda -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.SilkRoad.CardView.Outlined"
                    android:layout_marginHorizontal="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.FilledBox"
                        android:hint="¿A dónde ir?"
                        app:startIconDrawable="@drawable/ic_search_24"
                        app:startIconTint="@color/primary"
                        app:boxBackgroundColor="@color/transparent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/inputSearch"
                            android:textAppearance="@style/TextAppearance.SilkRoad.BodyLarge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />
                    </com.google.android.material.textfield.TextInputLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sección: Departamentos -->
                <TextView
                    android:id="@+id/tvCitiesTitle"
                    android:text="Departamentos"
                    android:textAppearance="@style/TextAppearance.SilkRoad.TitleLarge"
                    android:layout_marginHorizontal="@dimen/spacing_md"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDepartments"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_department"
                    tools:itemCount="5" />

                <!-- Sección: Empresas Mejor Calificadas -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginHorizontal="@dimen/spacing_md"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvBestRatedTitle"
                        android:text="Mejores calificadas"
                        android:textAppearance="@style/TextAppearance.SilkRoad.TitleLarge"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Ver todas"
                        android:textAppearance="@style/TextAppearance.SilkRoad.LabelLarge"
                        android:textColor="@color/primary"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="@dimen/spacing_sm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCompanies"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingBottom="@dimen/spacing_md"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:listitem="@layout/item_company"
                    tools:itemCount="3" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- NAVBAR LATERAL (SIDEBAR CLIENTE) -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navViewClient"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/menu_client"
        app:headerLayout="@layout/nav_header_client" />

</androidx.drawerlayout.widget.DrawerLayout>
