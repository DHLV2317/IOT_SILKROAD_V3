<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.SilkRoad.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_xs"
    android:layout_marginVertical="@dimen/spacing_sm"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <!-- Imagen miniatura -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgTourThumb"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="@color/surface_variant"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.SilkRoad.SmallComponent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_map_placeholder" />

        <!-- Badge de estado -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipStatus"
            style="@style/Widget.SilkRoad.Chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_md"
            app:layout_constraintStart_toEndOf="@id/imgTourThumb"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Activo" />

        <!-- Nombre del tour -->
        <TextView
            android:id="@+id/tvTourName"
            android:textAppearance="@style/TextAppearance.SilkRoad.TitleLarge"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgTourThumb"
            app:layout_constraintTop_toBottomOf="@id/chipStatus"
            tools:text="City Tour Lima" />

        <!-- Información adicional -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginStart="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@id/imgTourThumb"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imgTourThumb">

            <TextView
                android:id="@+id/tvPrice"
                android:textAppearance="@style/TextAppearance.SilkRoad.BodyMedium"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:drawablePadding="@dimen/spacing_xs"
                android:layout_marginEnd="@dimen/spacing_md"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="S/. 120.00" />

            <TextView
                android:id="@+id/tvCapacity"
                android:textAppearance="@style/TextAppearance.SilkRoad.BodyMedium"
                android:drawablePadding="@dimen/spacing_xs"
                app:drawableStartCompat="@drawable/ic_person_24"
                app:drawableTint="@color/text_secondary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="30 pers." />

        </LinearLayout>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="@dimen/spacing_md"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imgTourThumb" />

        <!-- Acciones -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                style="@style/Widget.SilkRoad.Button.Text"
                android:text="Editar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnView"
                style="@style/Widget.SilkRoad.Button.Text"
                android:text="Ver detalles"
                android:layout_marginStart="@dimen/spacing_sm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
