<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/M3_Card_Filled"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_xs"
    android:layout_marginBottom="@dimen/spacing_sm">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <TextView
            android:id="@+id/tExtraName"
            style="@style/M3_Title_Small"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extra X"/>

        <TextView
            android:id="@+id/tExtraPrice"
            style="@style/M3_Body_Medium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="S/. 10.00 por persona"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="@dimen/spacing_xs"
            android:layout_marginBottom="@dimen/spacing_sm"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="center"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinusExtra"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="-"
                android:textSize="@dimen/text_lg" />

            <TextView
                android:id="@+id/tExtraQty"
                style="@style/M3_Title_Large"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="0"
                android:layout_marginHorizontal="@dimen/spacing_md"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlusExtra"
                style="@style/Widget.Material3.Button.Icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="+"
                android:textSize="@dimen/text_lg" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>